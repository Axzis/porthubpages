{
  "entities": {
    "landingPage": {
      "title": "Landing Page",
      "description": "Represents a single landing page created by a user.",
      "type": "object",
      "properties": {
        "ownerId": {
          "type": "string",
          "description": "The ID of the user who owns this page."
        },
        "pageName": {
          "type": "string",
          "description": "The internal name of the landing page."
        },
        "pagePurpose": {
            "type": "string",
            "description": "A brief description of the page's purpose, used for AI content generation."
        },
        "slug": {
          "type": "string",
          "description": "The URL-friendly slug for the public page."
        },
        "status": {
          "type": "string",
          "enum": ["draft", "published"],
          "description": "The current status of the page."
        },
        "template": {
          "type": "string",
          "description": "The ID of the template used for this page."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the page was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the page was last updated."
        },
        "publishedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the page was published."
        },
        "brand": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "logoUrl": {
              "type": "string"
            }
          }
        },
        "seo": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "ogImageUrl": {
              "type": "string"
            }
          }
        },
        "style": {
          "type": "object",
          "properties": {
            "primaryColor": {
              "type": "string"
            },
            "font": {
              "type": "string"
            },
            "layout": {
              "type": "string"
            }
          }
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "required": ["ownerId", "pageName", "slug", "status", "template", "createdAt", "updatedAt"]
    },
    "lead": {
      "title": "Lead",
      "description": "Represents a lead captured from a landing page form.",
      "type": "object",
      "properties": {
        "pageId": {
          "type": "string",
          "description": "The ID of the page where the lead was captured."
        },
        "ownerId": {
          "type": "string",
          "description": "The ID of the user who owns the page."
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "phone": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "isRead": {
          "type": "boolean",
          "description": "Indicates if the lead has been read by the owner."
        }
      },
      "required": ["pageId", "ownerId", "email", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/landingPages/{landingPageId}": {
      "schema": {
        "$ref": "#/entities/landingPage"
      },
      "description": "Stores all landing pages created by users."
    },
    "/leads/{leadId}": {
      "schema": {
        "$ref": "#/entities/lead"
      },
      "description": "Stores leads captured from public landing page forms."
    }
  }
}
