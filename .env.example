# -----------------------------------------------------------------------------
# Environment Variables Example
#
# Salin file ini ke .env.local dan isi nilainya.
# Jangan pernah memasukkan file .env.local Anda ke dalam Git.
#
# Untuk deployment (misalnya di Vercel), variabel-variabel ini harus
# diatur di pengaturan lingkungan proyek Anda.
# -----------------------------------------------------------------------------

# Firebase
# Dapatkan ini dari Firebase Console Anda > Pengaturan Proyek > Umum > Aplikasi Anda > Firebase SDK snippet > Konfigurasi.
# Semua variabel Firebase ini aman untuk diekspos ke klien, sehingga diawali dengan NEXT_PUBLIC_.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Cloudinary
# Diperlukan untuk unggah gambar. Dapatkan ini dari dasbor Cloudinary Anda.
# CLOUDINARY_API_KEY dan CLOUDINARY_API_SECRET adalah rahasia dan TIDAK BOLEH diawali dengan NEXT_PUBLIC_.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Genkit/Google AI (Gemini)
# Diperlukan untuk fitur saran AI.
# Ini adalah rahasia dan TIDAK BOLEH diawali dengan NEXT_PUBLIC_.
GEMINI_API_KEY=
